# --- Google Gemini (required) ---------------------------------------------
# Server-only key for the real generateContent call. Never expose to the client.
GEMINI_API_KEY=your-gemini-api-key
# Optional override; defaults to gemini-flash-latest.
GEMINI_MODEL=gemini-flash-latest

# --- NVIDIA multi-LLM ensemble (optional: higher-quality itineraries) ------
# Server-only key for the OpenAI-compatible NVIDIA endpoint. A diverse panel of
# models drafts candidate plans in parallel and Gemini synthesizes the best one.
# If absent, Wanderlore runs the single-Gemini path unchanged (ensemble off).
NVIDIA_API_KEY=your-nvidia-api-key
# Optional overrides (sensible defaults apply if omitted):
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_PANEL_MODELS=nvidia/nemotron-3-super-120b-a12b,mistralai/mistral-large-3-675b-instruct-2512,openai/gpt-oss-120b
# PANEL_TIMEOUT_MS=12000
# PANEL_MIN_QUORUM=1
# MAX_GEO_PLACES=15

# --- Supabase (optional: enables saving + shareable trip links) -----------
# When connecting Supabase via the Vercel integration these are injected
# automatically. Locally, copy them from Supabase → Project Settings → API.
# If absent, the app still generates trips — only save/share is disabled.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (optional: enables "email this trip") -------------------------
# Server-only key. Sends from the verified intrafy.in domain. If absent, the
# app still works — the "Email this trip" action is simply hidden.
RESEND_API_KEY=your-resend-api-key

# --- App ------------------------------------------------------------------
# Public base URL used to build shareable links (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
